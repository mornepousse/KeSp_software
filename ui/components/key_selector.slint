import { Button, LineEdit, SpinBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { KeySelectorBridge, KeycodeEntry, ModalKind } from "../globals.slint";

export component KeySelector inherits Rectangle {
    width: 100%;
    height: 100%;
    background: #000000aa;

    TouchArea { clicked => { KeySelectorBridge.cancel(); } }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: min(parent.width - 32px, 720px);
        height: min(parent.height - 32px, 560px);
        background: Theme.bg-primary;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.accent-purple;

        TouchArea { }

        VerticalLayout {
            padding: 12px;
            spacing: 8px;

            // Title + search
            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: "Select Key";
                    color: Theme.accent-cyan;
                    font-size: 16px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
                LineEdit {
                    min-width: 140px;
                    max-width: 220px;
                    horizontal-stretch: 1;
                    placeholder-text: "Search...";
                    text <=> KeySelectorBridge.search-filter;
                    edited(text) => { KeySelectorBridge.search-changed(text); }
                }
            }

            // Keycode list (vertical — simple and reliable)
            Rectangle {
                vertical-stretch: 1;
                background: Theme.bg-surface;
                border-radius: 4px;
                clip: true;

                Flickable {
                    x: 4px;
                    y: 4px;
                    width: parent.width - 8px;
                    height: parent.height - 8px;

                    VerticalLayout {
                        spacing: 2px;

                        for entry[idx] in KeySelectorBridge.entries : Rectangle {
                            height: entry.code == -1 ? 26px : 30px;
                            background: entry.code == -1 ? transparent : Theme.button-bg;
                            border-radius: entry.code >= 0 ? 3px : 0px;

                            HorizontalLayout {
                                padding-left: entry.code == -1 ? 4px : 12px;
                                padding-right: 8px;

                                Text {
                                    text: entry.code == -1 ? entry.label : entry.label + "  (0x" + entry.category + ")";
                                    color: entry.code == -1 ? Theme.accent-orange : Theme.fg-primary;
                                    font-size: entry.code == -1 ? 12px : 11px;
                                    font-weight: entry.code == -1 ? 700 : 400;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }

                            if entry.code >= 0 : TouchArea {
                                clicked => { KeySelectorBridge.select-keycode(entry.code); }
                            }
                        }
                    }
                }
            }

            // MT / LT row
            HorizontalLayout {
                spacing: 6px;
                height: 32px;

                Text { text: "MT:"; color: Theme.fg-secondary; font-size: 11px; vertical-alignment: center; }
                SpinBox { min-width: 55px; horizontal-stretch: 1; value <=> KeySelectorBridge.mt-mod; minimum: 0; maximum: 15; }
                SpinBox { min-width: 55px; horizontal-stretch: 1; value <=> KeySelectorBridge.mt-key; minimum: 0; maximum: 231; }
                Button { text: "MT"; clicked => { KeySelectorBridge.apply-mt(); } }

                Rectangle { width: 1px; background: Theme.fg-secondary; }

                Text { text: "LT:"; color: Theme.fg-secondary; font-size: 11px; vertical-alignment: center; }
                SpinBox { min-width: 55px; horizontal-stretch: 1; value <=> KeySelectorBridge.lt-layer; minimum: 0; maximum: 15; }
                SpinBox { min-width: 55px; horizontal-stretch: 1; value <=> KeySelectorBridge.lt-key; minimum: 0; maximum: 231; }
                Button { text: "LT"; clicked => { KeySelectorBridge.apply-lt(); } }
            }

            // Hex + Cancel row
            HorizontalLayout {
                spacing: 6px;
                height: 32px;

                Text { text: "Hex:"; color: Theme.fg-secondary; font-size: 11px; vertical-alignment: center; }
                LineEdit {
                    min-width: 80px;
                    max-width: 120px;
                    horizontal-stretch: 1;
                    placeholder-text: "0x0000";
                    text <=> KeySelectorBridge.hex-input;
                }
                Button { text: "Apply"; clicked => { KeySelectorBridge.apply-hex(); } }

                Rectangle { horizontal-stretch: 1; }

                Button { text: "Cancel"; clicked => { KeySelectorBridge.cancel(); } }
            }
        }
    }
}
