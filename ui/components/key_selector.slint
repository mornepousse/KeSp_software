import { Button, LineEdit, SpinBox, ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { KeySelectorBridge, KeycodeEntry, ModalKind } from "../globals.slint";

export component KeySelector inherits Rectangle {
    // Full-screen semi-transparent backdrop
    width: 100%;
    height: 100%;
    background: #000000aa;

    // Click backdrop to cancel
    TouchArea {
        clicked => { KeySelectorBridge.cancel(); }
    }

    // Centered panel
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 720px;
        height: 520px;
        background: Theme.bg-primary;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.accent-purple;

        // Block clicks from passing through to backdrop
        TouchArea { }

        VerticalLayout {
            padding: 16px;
            spacing: 10px;

            // Title bar
            HorizontalLayout {
                spacing: 12px;

                Text {
                    text: "Select Key";
                    color: Theme.accent-cyan;
                    font-size: 18px;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                // Search field
                LineEdit {
                    width: 220px;
                    placeholder-text: "Search keycodes...";
                    text <=> KeySelectorBridge.search-filter;
                    edited(text) => {
                        KeySelectorBridge.search-changed(text);
                    }
                }
            }

            // Keycode grid area
            Rectangle {
                vertical-stretch: 1;
                background: Theme.bg-surface;
                border-radius: 4px;
                clip: true;

                property <int> cols: 9;
                property <length> btn-w: 72px;
                property <length> btn-h: 32px;
                property <length> gap: 4px;
                property <length> hdr-h: 28px;

                Flickable {
                    x: 8px;
                    y: 4px;
                    width: parent.width - 16px;
                    height: parent.height - 8px;

                    VerticalLayout {
                        spacing: 2px;
                        padding-top: 4px;
                        padding-bottom: 8px;

                        for entry[idx] in KeySelectorBridge.entries : Rectangle {
                            // Section header entries have code == -1
                            height: entry.code == -1 ? 28px : 32px;
                            // Headers span full width; buttons are compact
                            background: entry.code == -1
                                ? transparent
                                : Theme.button-bg;
                            border-radius: entry.code >= 0 ? 4px : 0px;

                            if entry.code == -1 : HorizontalLayout {
                                padding-left: 4px;
                                padding-top: 6px;

                                Text {
                                    text: entry.label;
                                    color: Theme.accent-orange;
                                    font-size: 13px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }

                            if entry.code >= 0 : HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;

                                Text {
                                    text: entry.label;
                                    color: Theme.fg-primary;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                            }

                            if entry.code >= 0 : TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    KeySelectorBridge.select-keycode(entry.code);
                                }
                            }
                        }
                    }
                }
            }

            // Bottom section: MT builder, LT builder, Hex input
            Rectangle {
                height: 44px;
                background: Theme.bg-secondary;
                border-radius: 4px;

                HorizontalLayout {
                    padding: 6px;
                    spacing: 8px;

                    // MT builder
                    Text {
                        text: "MT:";
                        color: Theme.fg-secondary;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                    SpinBox {
                        width: 70px;
                        value <=> KeySelectorBridge.mt-mod;
                        minimum: 0;
                        maximum: 15;
                    }
                    SpinBox {
                        width: 70px;
                        value <=> KeySelectorBridge.mt-key;
                        minimum: 0;
                        maximum: 231;
                    }
                    Button {
                        text: "Apply MT";
                        clicked => { KeySelectorBridge.apply-mt(); }
                    }

                    // Separator
                    Rectangle { width: 1px; background: Theme.fg-secondary; }

                    // LT builder
                    Text {
                        text: "LT:";
                        color: Theme.fg-secondary;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                    SpinBox {
                        width: 70px;
                        value <=> KeySelectorBridge.lt-layer;
                        minimum: 0;
                        maximum: 15;
                    }
                    SpinBox {
                        width: 70px;
                        value <=> KeySelectorBridge.lt-key;
                        minimum: 0;
                        maximum: 231;
                    }
                    Button {
                        text: "Apply LT";
                        clicked => { KeySelectorBridge.apply-lt(); }
                    }

                    // Separator
                    Rectangle { width: 1px; background: Theme.fg-secondary; }

                    // Hex input
                    Text {
                        text: "Hex:";
                        color: Theme.fg-secondary;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                    LineEdit {
                        width: 80px;
                        placeholder-text: "0x0000";
                        text <=> KeySelectorBridge.hex-input;
                    }
                    Button {
                        text: "Apply";
                        clicked => { KeySelectorBridge.apply-hex(); }
                    }
                }
            }

            // Cancel button
            HorizontalLayout {
                alignment: end;
                spacing: 8px;

                Button {
                    text: "Cancel";
                    clicked => { KeySelectorBridge.cancel(); }
                }
            }
        }
    }
}
