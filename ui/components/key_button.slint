import { Theme } from "../theme.slint";
import { KeycapData } from "../globals.slint";

export component KeyButton inherits Rectangle {
    in property <KeycapData> data;
    callback clicked(int);

    width: data.w;
    height: data.h;
    border-radius: 4px;
    background: data.color;
    border-width: 1px;
    border-color: #282a36;

    // Selection overlay (conditional, no ternary on parent properties)
    if data.selected : Rectangle {
        background: #bd93f980;
        border-width: 2px;
        border-color: #8be9fd;
        border-radius: 4px;
    }

    Text {
        text: data.label;
        color: #f8f8f2;
        font-size: 11px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if data.sublabel != "" : Text {
        y: parent.height - 14px;
        text: data.sublabel;
        color: #6272a4;
        font-size: 8px;
        horizontal-alignment: center;
        width: 100%;
    }

    TouchArea {
        clicked => { root.clicked(data.index); }
    }
}
