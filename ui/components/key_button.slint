import { Theme } from "../theme.slint";
import { KeycapData } from "../globals.slint";

export component KeyButton inherits Rectangle {
    in property <KeycapData> data;
    in property <float> render-scale: 1.0;
    callback clicked(int);

    // Width and height controlled by parent (KeyboardView applies scaling)
    border-radius: 4px;
    background: data.color;
    border-width: 1px;
    border-color: #282a36;

    if data.selected : Rectangle {
        background: #bd93f980;
        border-width: 2px;
        border-color: #8be9fd;
        border-radius: 4px;
    }

    Text {
        text: data.label;
        color: #f8f8f2;
        font-size: max(7px, 11px * root.render-scale);
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if data.sublabel != "" : Text {
        y: parent.height - max(10px, 14px * root.render-scale);
        text: data.sublabel;
        color: #6272a4;
        font-size: max(6px, 8px * root.render-scale);
        horizontal-alignment: center;
        width: 100%;
    }

    TouchArea {
        clicked => { root.clicked(data.index); }
    }
}
