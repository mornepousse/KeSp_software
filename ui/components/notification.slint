import { Theme } from "../theme.slint";
import { AppState } from "../globals.slint";

export component Notification inherits Rectangle {
    width: 100%;
    height: 40px;
    visible: AppState.notification-visible;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.bg-secondary.transparentize(0.15);
        border-radius: 6px;

        HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            alignment: center;

            Text {
                text: AppState.notification-text;
                color: Theme.accent-green;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
