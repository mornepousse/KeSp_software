// Shared data structures
export struct KeycapData {
    x: length,
    y: length,
    w: length,
    h: length,
    rotation: float,
    rotation-cx: length,
    rotation-cy: length,
    label: string,
    sublabel: string,
    keycode: int,
    color: color,
    selected: bool,
    index: int,
}

export struct LayerInfo {
    index: int,
    name: string,
    active: bool,
}

export struct PortInfo {
    name: string,
    path: string,
}

export enum ConnectionState { disconnected, connecting, connected }
export enum ActiveTab { keymap, advanced, macros, stats, settings }

// Global singletons for Rust<->Slint bridge
export global AppState {
    in-out property <ConnectionState> connection: ConnectionState.disconnected;
    in-out property <ActiveTab> active-tab: ActiveTab.keymap;
    in-out property <string> status-text: "Disconnected";
    in-out property <bool> spinner-visible: false;
    in-out property <string> firmware-version: "";
    in-out property <int> wpm: 0;
    in-out property <string> notification-text: "";
    in-out property <bool> notification-visible: false;
}

export global ConnectionBridge {
    in property <[PortInfo]> ports;
    in property <[string]> port-names;
    in-out property <string> selected-port: "";
    in-out property <int> selected-port-index: -1;
    callback connect();
    callback disconnect();
    callback refresh-ports();
}

export global KeymapBridge {
    in property <[KeycapData]> keycaps;
    in property <[LayerInfo]> layers;
    in property <length> layout-width: 780px;
    in property <length> layout-height: 360px;
    in-out property <int> selected-key-index: -1;
    in-out property <int> active-layer: 0;
    in-out property <string> selected-key-label: "";
    in-out property <bool> heatmap-enabled: false;
    in-out property <string> rename-text: "";
    callback select-key(int);
    callback switch-layer(int);
    callback change-key(int, int); // key-index, new-keycode
    callback toggle-heatmap(bool);
    callback export-keymap();
    callback import-keymap();
    callback rename-layer(int, string); // layer_index, new_name
}

export struct KeycodeEntry {
    code: int,
    label: string,
    category: string,
}

export enum ModalKind { none, key-selector }

export global KeySelectorBridge {
    in property <[KeycodeEntry]> entries;
    in-out property <string> search-filter: "";
    in-out property <ModalKind> active-modal: ModalKind.none;
    in-out property <int> editing-key-index: -1;
    // MT builder
    in-out property <int> mt-mod: 2;
    in-out property <int> mt-key: 4;
    // LT builder
    in-out property <int> lt-layer: 1;
    in-out property <int> lt-key: 44;
    // Hex input
    in-out property <string> hex-input: "";

    callback select-keycode(int); // code selected
    callback cancel();
    callback apply-mt();
    callback apply-lt();
    callback apply-hex();
    callback search-changed(string);
}

export global StatsBridge {
    in property <[KeycapData]> heatmap-keycaps;
    in property <length> layout-width: 780px;
    in property <length> layout-height: 360px;
    in-out property <bool> heatmap-active: false;
    in property <string> stats-summary: "";
    in property <int> total-keypresses: 0;
    callback refresh-stats();
    callback export-csv();
}

export struct TapDanceSlot {
    index: int,
    tap1: string,
    tap2: string,
    tap3: string,
    hold: string,
    tap1-code: int,
    tap2-code: int,
    tap3-code: int,
    hold-code: int,
}

export struct ComboEntry {
    index: int,
    key1-label: string,
    key2-label: string,
    result-label: string,
    key1-row: int,
    key1-col: int,
    key2-row: int,
    key2-col: int,
    result-code: int,
}

export struct LeaderEntry {
    index: int,
    sequence: string,   // "A -> B -> C"
    result: string,     // decoded keycode + mod
    result-code: int,
    result-mod: int,
}

export struct KeyOverrideEntry {
    index: int,
    trigger-key: string,
    trigger-mod: string,
    result-key: string,
    result-mod: string,
}

export struct BtSlotInfo {
    index: int,
    status: string,     // "Connected", "Paired", "Empty"
    name: string,
    addr: string,
}

export global AdvancedBridge {
    in property <[TapDanceSlot]> tap-dance-slots;
    in property <[ComboEntry]> combos;
    in property <[LeaderEntry]> leaders;
    in property <[KeyOverrideEntry]> key-overrides;
    in property <[BtSlotInfo]> bt-slots;
    in property <string> bt-mode: "USB";
    in property <int> bt-active-slot: 0;
    in-out property <bool> show-tap-dance: true;
    in-out property <bool> show-combos: true;
    in-out property <bool> show-leader: false;
    in-out property <bool> show-ko: false;
    in-out property <bool> show-bt: false;
    callback refresh-all();
    callback save-td(int);
    callback delete-combo(int);
    callback delete-leader(int);
    callback delete-ko(int);
    callback bt-next();
    callback bt-prev();
    callback bt-pair();
    callback bt-disconnect();
    callback bt-toggle-usb-bt();

    // Auto Shift
    in-out property <bool> autoshift-enabled: false;
    in-out property <int> autoshift-timeout: 200;
    in-out property <bool> show-autoshift: false;
    callback save-autoshift();

    // Tri-Layer
    in-out property <int> tri-layer1: 1;
    in-out property <int> tri-layer2: 2;
    in-out property <int> tri-layer3: 3;
    in-out property <bool> show-tri-layer: false;
    callback save-tri-layer();

    // Tamagotchi
    in-out property <bool> show-tamagotchi: false;
    in property <int> tama-hunger: 0;
    in property <int> tama-happiness: 0;
    in property <int> tama-energy: 0;
    in property <int> tama-health: 0;
    callback tama-feed();
    callback tama-play();
    callback tama-sleep();
    callback tama-meds();
    callback refresh-tama();
}

export struct MacroStepInfo {
    action-type: string,  // "press", "release", "tap", "delay"
    keycode: int,
    label: string,        // decoded display name (key name or delay ms)
    delay-ms: int,
}

export struct MacroInfo {
    slot: int,
    name: string,
    steps: int,  // number of steps
}

export global MacroBridge {
    in property <[MacroInfo]> macros;
    in property <[MacroStepInfo]> current-steps;
    in-out property <int> selected-macro: -1;
    in-out property <string> macro-name: "";
    in-out property <string> delay-input: "50";
    callback refresh-macros();
    callback select-macro(int);
    callback save-macro();
    callback delete-macro(int);
    callback add-step(string, int);    // action-type, keycode-or-delay
    callback remove-step(int);         // step index
    callback move-step-up(int);        // step index
    callback move-step-down(int);      // step index
    callback new-macro();              // create a new empty macro
}

export global SettingsBridge {
    // Layout
    in property <[string]> available-layouts;
    in-out property <int> selected-layout-index: 0;
    callback change-layout(int);

    // Backup / Restore
    callback backup();
    callback restore();

    // OTA
    in-out property <float> ota-progress: 0;
    in-out property <string> ota-status: "";
    in-out property <bool> ota-in-progress: false;
    in-out property <string> ota-file-name: "";
    callback ota-select-file();
    callback ota-start();

    // DFU / Flasher
    in property <[string]> prog-ports;
    in-out property <int> selected-prog-port: 0;
    in-out property <string> prog-path: "";
    in-out property <float> flash-progress: 0;
    in-out property <string> flash-status: "";
    callback flash-select-file();
    callback flash-start();
}
