// Shared data structures
export struct KeycapData {
    x: length,
    y: length,
    w: length,
    h: length,
    rotation: float,
    rotation-cx: length,
    rotation-cy: length,
    label: string,
    sublabel: string,
    keycode: int,
    color: color,
    selected: bool,
    index: int,
}

export struct LayerInfo {
    index: int,
    name: string,
    active: bool,
}

export struct PortInfo {
    name: string,
    path: string,
}

export enum ConnectionState { disconnected, connecting, connected }
export enum ActiveTab { keymap, advanced, macros, stats, settings }

// Global singletons for Rust<->Slint bridge
export global AppState {
    in-out property <ConnectionState> connection: ConnectionState.disconnected;
    in-out property <ActiveTab> active-tab: ActiveTab.keymap;
    in-out property <string> status-text: "Disconnected";
    in-out property <bool> spinner-visible: false;
    in-out property <string> firmware-version: "";
    in-out property <int> wpm: 0;
}

export global ConnectionBridge {
    in property <[PortInfo]> ports;
    in-out property <string> selected-port: "";
    callback connect();
    callback disconnect();
    callback refresh-ports();
}

export global KeymapBridge {
    in property <[KeycapData]> keycaps;
    in property <[LayerInfo]> layers;
    in-out property <int> selected-key-index: -1;
    in-out property <int> active-layer: 0;
    in-out property <string> selected-key-label: "";
    in-out property <bool> heatmap-enabled: false;
    callback select-key(int);
    callback switch-layer(int);
    callback change-key(int, int); // key-index, new-keycode
}

export struct KeycodeEntry {
    code: int,
    label: string,
    category: string,
}

export enum ModalKind { none, key-selector }

export global KeySelectorBridge {
    in property <[KeycodeEntry]> entries;
    in-out property <string> search-filter: "";
    in-out property <ModalKind> active-modal: ModalKind.none;
    in-out property <int> editing-key-index: -1;
    // MT builder
    in-out property <int> mt-mod: 2;
    in-out property <int> mt-key: 4;
    // LT builder
    in-out property <int> lt-layer: 1;
    in-out property <int> lt-key: 44;
    // Hex input
    in-out property <string> hex-input: "";

    callback select-keycode(int); // code selected
    callback cancel();
    callback apply-mt();
    callback apply-lt();
    callback apply-hex();
    callback search-changed(string);
}

export struct TapDanceSlot {
    index: int,
    tap1: string,
    tap2: string,
    tap3: string,
    hold: string,
    tap1-code: int,
    tap2-code: int,
    tap3-code: int,
    hold-code: int,
}

export struct ComboEntry {
    index: int,
    key1-label: string,
    key2-label: string,
    result-label: string,
    key1-row: int,
    key1-col: int,
    key2-row: int,
    key2-col: int,
    result-code: int,
}

export global AdvancedBridge {
    in property <[TapDanceSlot]> tap-dance-slots;
    in property <[ComboEntry]> combos;
    in-out property <bool> show-tap-dance: true;
    in-out property <bool> show-combos: true;
    in-out property <bool> show-leader: false;
    in-out property <bool> show-ko: false;
    in-out property <bool> show-bt: false;
    callback refresh-all();
    callback save-td(int);
    callback delete-combo(int);
}
