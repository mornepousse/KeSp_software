import { Button, ComboBox, ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { SettingsBridge } from "../globals.slint";

component SectionHeader inherits Rectangle {
    in property <string> title;
    height: 36px;
    background: Theme.bg-secondary;
    border-radius: 4px;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        alignment: start;
        Text {
            text: title;
            color: Theme.accent-purple;
            font-size: 14px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

component ProgressBar inherits Rectangle {
    in property <float> value: 0;
    height: 16px;
    border-radius: 4px;
    background: Theme.bg-secondary;

    Rectangle {
        x: 0;
        y: 0;
        height: parent.height;
        width: parent.width * max(0, min(value, 1));
        border-radius: 4px;
        background: Theme.accent-green;
    }
}

export component TabSettings inherits Rectangle {
    background: Theme.bg-primary;

    ScrollView {
        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            // ========== Keyboard Layout ==========
            SectionHeader { title: "Keyboard Layout"; }

            Rectangle {
                background: Theme.bg-surface;
                border-radius: 6px;
                height: 56px;

                HorizontalLayout {
                    padding: 12px;
                    spacing: 12px;
                    alignment: start;

                    Text {
                        text: "Display layout:";
                        color: Theme.fg-primary;
                        font-size: 13px;
                        vertical-alignment: center;
                    }

                    ComboBox {
                        width: 200px;
                        model: SettingsBridge.available-layouts;
                        current-index <=> SettingsBridge.selected-layout-index;
                        selected(value) => {
                            SettingsBridge.change-layout(self.current-index);
                        }
                    }
                }
            }

            // ========== Backup & Restore ==========
            SectionHeader { title: "Backup & Restore"; }

            Rectangle {
                background: Theme.bg-surface;
                border-radius: 6px;
                height: 72px;

                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Text {
                        text: "Export the full keyboard configuration as JSON, or restore from a previous backup.";
                        color: Theme.fg-secondary;
                        font-size: 11px;
                        wrap: word-wrap;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Button {
                            text: "Backup";
                            clicked => { SettingsBridge.backup(); }
                        }

                        Button {
                            text: "Restore";
                            clicked => { SettingsBridge.restore(); }
                        }
                    }
                }
            }

            // ========== OTA Firmware Update ==========
            SectionHeader { title: "OTA Firmware Update"; }

            Rectangle {
                background: Theme.bg-surface;
                border-radius: 6px;

                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Text {
                        text: "Flash firmware over the USB CDC serial link (the same port used for configuration).";
                        color: Theme.fg-secondary;
                        font-size: 11px;
                        wrap: word-wrap;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Button {
                            text: "Select .bin";
                            enabled: !SettingsBridge.ota-in-progress;
                            clicked => { SettingsBridge.ota-select-file(); }
                        }

                        Text {
                            text: SettingsBridge.ota-file-name == "" ? "No file selected" : SettingsBridge.ota-file-name;
                            color: SettingsBridge.ota-file-name == "" ? Theme.fg-secondary : Theme.fg-primary;
                            font-size: 12px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Button {
                            text: SettingsBridge.ota-in-progress ? "Flashing..." : "Start OTA";
                            enabled: SettingsBridge.ota-file-name != "" && !SettingsBridge.ota-in-progress;
                            clicked => { SettingsBridge.ota-start(); }
                        }
                    }

                    if SettingsBridge.ota-status != "" : VerticalLayout {
                        spacing: 4px;

                        ProgressBar {
                            value: SettingsBridge.ota-progress;
                        }

                        Text {
                            text: SettingsBridge.ota-status;
                            color: SettingsBridge.ota-progress >= 1.0 ? Theme.accent-green : Theme.accent-cyan;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            // ========== ESP32 Flasher (Programming Port) ==========
            SectionHeader { title: "ESP32 Flasher (Programming Port)"; }

            Rectangle {
                background: Theme.bg-surface;
                border-radius: 6px;

                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Text {
                        text: "Flash firmware via the CH340/CP2102 programming port (SLIP bootloader protocol).";
                        color: Theme.fg-secondary;
                        font-size: 11px;
                        wrap: word-wrap;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Text {
                            text: "Port:";
                            color: Theme.fg-primary;
                            font-size: 13px;
                            vertical-alignment: center;
                        }

                        ComboBox {
                            width: 200px;
                            model: SettingsBridge.prog-ports;
                            current-index <=> SettingsBridge.selected-prog-port;
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Button {
                            text: "Select Firmware";
                            clicked => { SettingsBridge.flash-select-file(); }
                        }

                        Text {
                            text: SettingsBridge.prog-path == "" ? "No file selected" : SettingsBridge.prog-path;
                            color: SettingsBridge.prog-path == "" ? Theme.fg-secondary : Theme.fg-primary;
                            font-size: 12px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Button {
                            text: "Flash";
                            enabled: SettingsBridge.prog-path != "" && SettingsBridge.flash-progress == 0;
                            clicked => { SettingsBridge.flash-start(); }
                        }
                    }

                    if SettingsBridge.flash-status != "" : VerticalLayout {
                        spacing: 4px;

                        ProgressBar {
                            value: SettingsBridge.flash-progress;
                        }

                        Text {
                            text: SettingsBridge.flash-status;
                            color: SettingsBridge.flash-progress >= 1.0 ? Theme.accent-green : Theme.accent-cyan;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            // Bottom spacer
            Rectangle {
                height: 16px;
            }
        }
    }
}
